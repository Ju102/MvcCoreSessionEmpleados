@model List<Empleado>

<div class="container">
    <h2 class="text-success">Session Empleados by ID</h2>
    @if (Model != null && Model.Count != 0)
    {
        <table class="table table-primary table-bordered">
            <thead>
                <tr>
                    <th>Apellido</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (Empleado empleado in Model)
                {
                    <tr>
                        <td>@empleado.Apellido</td>
                        <td><a class="btn btn-success" asp-action="SessionEmpleadosById" asp-route-idempleado="@empleado.IdEmpleado">Almacenar</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
<div class="container">
    <a asp-action="ListaEmpleadosById">Mostrar Lista por IDs Almacenada</a>
</div>