@model List<Empleado>

<div class="container">
    <h2>Session Salarios</h2>
    @if (Model != null && Model.Count != 0)
    {
        <table class="table table-primary table-bordered">
            <thead>
                <tr>
                    <th>Apellido</th>
                    <th>Salario</th>
                </tr>
            </thead>
            <tbody>
                @foreach (Empleado empleado in Model)
                {
                    <tr>
                        <td>@empleado.Apellido</td>
                        <td>
                            @empleado.Salario.ToString("n0")€
                            <a class="btn btn-success" asp-action="SessionSalarios" asp-route-salario="@empleado.Salario">Almacenar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
<div class="container">
    <a asp-action="SumaSalarial">Mostrar Suma Salarial</a>
</div>